{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @goodagent/shared build && pnpm --filter @goodagent/web build",
  "outputDirectory": "apps/web/dist",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=6144"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://goodagentids.xyz/api/:path*" },
    { "source": "/host/:path*", "destination": "https://goodagentids.xyz/host/:path*" },
    { "source": "/((?!assets/|llms.txt|.*\\.\\w+$).*)", "destination": "/index.html" }
  ]
}
