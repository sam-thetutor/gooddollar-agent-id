{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @goodagent/shared build && pnpm --filter @goodagent/web build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://gcopilot-api.geinz.lol/:path*" },
    { "source": "/host/:path*", "destination": "https://gcopilot-api.geinz.lol/host/:path*" },
    { "source": "/((?!assets/|llms.txt|.*\\.\\w+$).*)", "destination": "/index.html" }
  ]
}
