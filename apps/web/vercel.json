{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @goodagent/shared build && pnpm --filter @goodagent/web build",
  "outputDirectory": "dist",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=6144"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://gcopilot-api.geinz.lol/:path*" },
    { "source": "/host/:path*", "destination": "https://gcopilot-api.geinz.lol/host/:path*" },
    { "source": "/((?!assets/|llms.txt|.*\\.\\w+$).*)", "destination": "/index.html" }
  ]
}
