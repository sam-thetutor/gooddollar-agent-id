generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id        String   @id @default(cuid())
  eventType String   @map("event_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// GoodDollar Agent ID — a signed Proof-of-Human credential for an AI agent.
// Numeric fields are stored as decimal strings to round-trip uint256/uint64
// exactly (see packages/agent-id wire form).
model AgentCredential {
  agent             String    @id
  operator          String
  humanRoot         String    @map("human_root")
  nonce             String    @default("0")
  issuedAt          String    @map("issued_at")
  expiresAt         String    @map("expires_at")
  signature         String
  chainId           Int       @map("chain_id")
  verifyingContract String    @map("verifying_contract")
  // True when the agent proved possession of its key at issue time (signed an
  // AgentAuth challenge). Distinguishes self-attested agents from ones an
  // operator merely named by address.
  agentProven       Boolean   @default(false) @map("agent_proven")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([operator])
  @@index([humanRoot])
  @@map("agent_credentials")
}

// Telegram UBI-reminder bot: one row per (chat, wallet) pair. A chat can watch
// several wallets. `lastRemindedDay` stores the UBIScheme `currentDay` of the
// last reminder sent, so each wallet is pinged at most once per claim cycle.
model TelegramSubscriber {
  id              String    @id @default(cuid())
  chatId          String    @map("chat_id")
  wallet          String
  active          Boolean   @default(true)
  lastRemindedDay String?   @map("last_reminded_day")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([chatId, wallet])
  @@index([active])
  @@map("telegram_subscribers")
}

// Autonomous agent hosting — one row per PM2-supervised deploy (apps/host).
model DeployedAgent {
  id                    String    @id @default(cuid())
  displayName           String    @map("display_name")
  template              String    @default("gaming")
  status                String    @default("pending_payment")
  agentAddress          String?   @unique @map("agent_address")
  walletDerivationIndex Int?      @map("wallet_derivation_index")
  operatorWallet        String?   @map("operator_wallet")
  ownerWallet           String?   @map("owner_wallet")
  disabledSkills        String?   @map("disabled_skills") @db.Text
  configuration         String?   @db.Text
  lastHeartbeatAt       DateTime? @map("last_heartbeat_at")
  pm2Name               String?   @map("pm2_name")
  lastError             String?   @map("last_error")
  deployPaymentTx       String?   @map("deploy_payment_tx")
  telegramBotTokenEnc   String?   @map("telegram_bot_token_enc") @db.Text
  plan                  String    @default("one_time")
  expiresAt             DateTime? @map("expires_at")
  deployedAt            DateTime? @map("deployed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  skills   SkillInstall[]
  payments DeployPayment[]
  matches  DeployMatch[]
  refills  DeployRefill[]
  logLines DeployLogLine[]

  @@index([ownerWallet])
  @@index([status])
  @@map("deployed_agents")
}

// GameArena (and future skills) — durable match ledger per deploy.
model DeployMatch {
  id              String   @id @default(cuid())
  deployedAgentId String   @map("deployed_agent_id")
  matchId         String   @map("match_id")
  gameType        Int      @map("game_type")
  wagerGs         Decimal  @map("wager_gs")
  result          String
  mode            String   @default("offchain")
  playedAt        DateTime @map("played_at")
  createdAt       DateTime @default(now()) @map("created_at")

  deployedAgent DeployedAgent @relation(fields: [deployedAgentId], references: [id], onDelete: Cascade)

  @@unique([deployedAgentId, matchId])
  @@index([deployedAgentId, playedAt])
  @@map("deploy_matches")
}

model DeployRefill {
  id              String   @id @default(cuid())
  deployedAgentId String   @map("deployed_agent_id")
  priceGs         Decimal  @map("price_gs")
  txHash          String   @map("tx_hash")
  refilledAt      DateTime @map("refilled_at")
  createdAt       DateTime @default(now()) @map("created_at")

  deployedAgent DeployedAgent @relation(fields: [deployedAgentId], references: [id], onDelete: Cascade)

  @@unique([deployedAgentId, txHash])
  @@index([deployedAgentId, refilledAt])
  @@map("deploy_refills")
}

model DeployLogLine {
  id              String   @id @default(cuid())
  deployedAgentId String   @map("deployed_agent_id")
  message         String   @db.Text
  loggedAt        DateTime @map("logged_at")
  createdAt       DateTime @default(now()) @map("created_at")

  deployedAgent DeployedAgent @relation(fields: [deployedAgentId], references: [id], onDelete: Cascade)

  @@index([deployedAgentId, loggedAt])
  @@map("deploy_log_lines")
}

model SkillInstall {
  id              String    @id @default(cuid())
  deployedAgentId String    @map("deployed_agent_id")
  skillId         String    @map("skill_id")
  registryPath    String    @map("registry_path")
  status          String    @default("installed")
  configJson      String?   @map("config_json") @db.Text
  lastError       String?
  activatedAt     DateTime? @map("activated_at")

  deployedAgent DeployedAgent @relation(fields: [deployedAgentId], references: [id], onDelete: Cascade)

  @@unique([deployedAgentId, skillId])
  @@map("skill_installs")
}

model DeployPayment {
  id              String   @id @default(cuid())
  deployedAgentId String?  @map("deployed_agent_id")
  amountUsd       Decimal  @map("amount_usd")
  txHash          String?  @map("tx_hash")
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")

  deployedAgent DeployedAgent? @relation(fields: [deployedAgentId], references: [id])

  @@map("deploy_payments")
}
