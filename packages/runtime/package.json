  },
  "dependencies": {
    "@goodagent/agent-id": "workspace:*",
    "@goodagent/db": "workspace:*",
    "@goodagent/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
