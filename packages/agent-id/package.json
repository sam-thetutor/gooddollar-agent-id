{
  "name": "@goodagent/agent-id",
  "version": "0.5.0",
  "description": "GoodDollar Agent ID — passport-free Proof-of-Human credentials for AI agents (EIP-712), with ERC-8004 interop. Verify that an agent is backed by a real, currently-verified GoodDollar human.",
  "keywords": [
    "gooddollar",
    "agent",
    "identity",
    "proof-of-human",
    "erc-8004",
    "eip-712",
    "celo",
    "ai-agents",
    "sybil-resistance"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "viem": "^2.31.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.32",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
