{
  "name": "@goodagent/mcp-server",
  "version": "0.4.0",
  "description": "Model Context Protocol server for verifying GoodDollar Agent IDs and reading GoodDollar state on Celo. Read-only, non-custodial.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gooddollar",
    "celo",
    "agent",
    "identity",
    "proof-of-human",
    "erc-8004"
  ],
  "homepage": "https://github.com/samthetutor/gooddollar-agent-id#readme",
  "bin": {
    "gooddollar-mcp": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly --declaration && node build.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@goodagent/agent-id": "workspace:*",
    "@goodagent/chain": "workspace:*",
    "@goodagent/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@types/node": "^22.15.32",
    "esbuild": "^0.24.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
