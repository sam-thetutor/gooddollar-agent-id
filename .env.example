# Web app (Vite)
VITE_WALLETCONNECT_PROJECT_ID=
VITE_API_BASE_URL=http://localhost:3001
VITE_CELO_RPC_URL=https://forno.celo.org

# Database
# Local Docker:    postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot
# Supabase pooler: postgresql://postgres.<TENANT>:<PASSWORD>@<HOST>:5432/postgres?schema=gcopilot
# App tables live in a dedicated `gcopilot` schema to avoid clashing with managed tables.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot

# GoodDollar / Celo
GOODDOLLAR_ENV=production
CELO_RPC_URL=https://forno.celo.org

# AgentVault (G$ stake) — deployed contract address on Celo mainnet
AGENT_VAULT_ADDRESS=

# API
API_PORT=3001

# Contract deployment (Foundry) — only needed to deploy AgentVault
DEPLOYER_PRIVATE_KEY=
