# Web app (Vite)
# Local dev: point at production API when local Postgres isn't reachable from your machine.
# Use /api to proxy to localhost:3001 (needs DATABASE_URL the API can reach).
VITE_API_BASE_URL=https://gcopilot-api.geinz.lol
VITE_API_PROXY_TARGET=http://localhost:3001
VITE_HOST_BASE_URL=http://localhost:3002
# Set to 1 when running `pnpm dev:host` so the deploy pipeline uses local host code (not production).
VITE_HOST_USE_LOCAL=1
# Deploy pipeline + PM2 control. In dev, set to http://localhost:3002 to test local host code.
# Omit VITE_HOST_USE_LOCAL to fall back to production host (gcopilot-api.geinz.lol/host).
# Deploy list reads Postgres — use production when local DB isn't reachable.
VITE_HOST_LIST_BASE_URL=https://gcopilot-api.geinz.lol/host
VITE_CELO_RPC_URL=https://forno.celo.org
# Reown / WalletConnect project id — required for mobile wallet deep links (MetaMask etc.)
# Create at https://cloud.reown.com and allow your site origins.
VITE_WALLETCONNECT_PROJECT_ID=e4f0acb8bbf35146eb2bce8c7006d1c3

# Database
# Local Docker:    postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot
# Supabase pooler: postgresql://postgres.<TENANT>:<PASSWORD>@<HOST>:5432/postgres?schema=gcopilot
# App tables live in a dedicated `gcopilot` schema to avoid clashing with managed tables.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot

# GoodDollar / Celo
GOODDOLLAR_ENV=production
CELO_RPC_URL=https://forno.celo.org

# AgentVault (G$ stake) — deployed contract address on Celo mainnet
AGENT_VAULT_ADDRESS=

# API
API_PORT=3001
API_BASE=https://gcopilot-api.geinz.lol

# Autonomous deploy host (apps/host — Phase 2)
HOST_PORT=3010
HOST_INTERNAL_SECRET=
HOST_DEV_SKIP_PAYMENT=1
# Production (Vercel): use /host — rewrites to gcopilot-api.geinz.lol/host in vercel.json

# Telegram UBI reminder bot (apps/telegram-bot)
# Create a bot with @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=
# Agent wallet for @goodbot_real_bot (GoodAgent ID on Celo mainnet)
TELEGRAM_BOT_AGENT_ADDRESS=0x1Ef8CA5686F2C2308a9E94c4D79626700A1bB4E7
# How often (minutes) the bot scans subscribers for unclaimed UBI.
REMINDER_INTERVAL_MINUTES=15

# Contract deployment (Foundry) — only needed to deploy AgentVault
DEPLOYER_PRIVATE_KEY=

# Demo agent registration script (apps/api/register-demo-agent.mts)
# GoodDollar-verified operator with >= 250 G$ on Celo
OPERATOR_PRIVATE_KEY=

# Autonomous agent deploy (packages/runtime — Phase 1 spike)
# Fresh mnemonic for HD agent wallets only — never reuse personal wallets
# Must be quoted (12 or 24 space-separated BIP39 words); dotenv reads only the first word otherwise.
DEPLOY_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"
# Relayer wallet — funds new agents with G$ + CELO; also relays attestations
PRIVATE_KEY=
# Play-wallet subsidy sent on each deploy (from PRIVATE_KEY treasury)
AGENT_INITIAL_GS=200
AGENT_INITIAL_CELO=1
# Where per-agent meta + PM2 configs live (local default: .goodagent/agents)
AGENTS_ROOT=
# GameArena HTTP proxy — one residential egress IP per agent (VPS datacenter IP is rate-limited).
# Option A (recommended): session template — {deployId} becomes a unique sticky session per agent.
# GAMEARENA_PROXY_TEMPLATE=http://user-session-{deployId}:pass@proxy.provider.com:8080
# Option B: explicit pool — agents pick a stable slot via hash(deployId) % pool.length.
# GAMEARENA_PROXY_POOL=http://user:pass@host1:8080,http://user:pass@host2:8080
GAMEARENA_PROXY_TEMPLATE=
GAMEARENA_PROXY_POOL=
# AES key for encrypting bot tokens in DB (Phase 2+)
ENCRYPTION_SECRET=
# Override if telegram-bot lives elsewhere on VPS
# TELEGRAM_BOT_APP_PATH=/home/geinz/gcopilot/apps/telegram-bot
