MINI_APP_URL=http://localhost:5173

# WalletConnect (Phase 3+)
VITE_WALLETCONNECT_PROJECT_ID=
# Mini App → API base URL (must be reachable from the user's device/Telegram)
VITE_API_BASE_URL=http://localhost:3001
