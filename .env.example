# Database (Phase 2+)
# Local Docker:   postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot
# Supabase pooler: postgresql://postgres.<TENANT>:<PASSWORD>@<HOST>:5432/postgres?schema=gcopilot
# App tables live in a dedicated `gcopilot` schema to avoid clashing with Supabase's managed tables.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gcopilot?schema=gcopilot

